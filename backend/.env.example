# HTTP sunucu adresi
ADDR=:8080

# Postgres bağlantısı (docker-compose ile uyumlu varsayılan)
DATABASE_URL=postgres://toplanti:toplanti@localhost:5434/toplanti?sslmode=disable

# Ses parçalarının yazılacağı kök dizin
AUDIO_DIR=./data/audio

# Frontend origin (CORS)
CORS_ORIGIN=http://localhost:5173

# --- Sağlayıcılar ---
# Yapılandırma boşsa ilgili katman "stub" (sahte) çalışır.

# ASR (ses → metin) önceliği: yerel whisper.cpp > OpenAI Whisper > stub.
#
# ÖNERİLEN: yerel whisper.cpp (offline, API'siz, ses cihazdan çıkmaz).
#   Kurulum: scripts/setup_whisper.sh   (whisper-cli + ffmpeg + model)
#   WHISPER_MODEL ayarlıysa bu kullanılır (uzun ses için 25MB limiti YOK).
WHISPER_BIN=whisper-cli
WHISPER_MODEL=
WHISPER_LANG=tr

# Alternatif: OpenAI Whisper API (WHISPER_MODEL boşsa ve bu doluysa kullanılır).
OPENAI_API_KEY=
ASR_MODEL=whisper-1

# LLM (özet) önceliği: yerel Ollama > Google Gemini > stub.
#
# ÖNERİLEN: yerel Ollama (offline, API'siz, veri cihazdan çıkmaz).
#   Kurulum: brew install ollama && ollama serve && ollama pull qwen2.5:7b
#   OLLAMA_MODEL ayarlıysa bu kullanılır.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Alternatif: Google Gemini API (OLLAMA_MODEL boşsa ve bu doluysa kullanılır).
GOOGLE_API_KEY=
LLM_MODEL=gemini-2.5-flash

# Mail önceliği: yerel/kurum-içi SMTP > Resend (bulut) > stub.
#
# ÖNERİLEN: yerel/kurum-içi SMTP (veri kurumun kendi mail altyapısından geçer).
#   Geliştirme/offline demo: `docker compose up -d mailpit` → SMTP :1025, gelen kutusu http://localhost:8025
#   SMTP_HOST ayarlıysa bu kullanılır. SMTP_USER boşsa kimlik doğrulamasız gönderir (Mailpit).
SMTP_HOST=
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Alternatif: Resend (bulut). SMTP_HOST boşsa ve bu doluysa kullanılır.
RESEND_API_KEY=

# Giden "from" adresi (SMTP ve Resend için ortak).
MAIL_FROM=toplanti@example.com
